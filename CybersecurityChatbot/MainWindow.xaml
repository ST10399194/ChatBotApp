<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Bot"
        Height="700" Width="900"
        Background="#0A0E1A"
        FontFamily="Consolas">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0" Background="#0D1B2A" Margin="0,0,0,4">

            <TextBlock Text="⚡ CyberSecurity Bot"
                       Foreground="#00FFFF"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,8"/>

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="12,0,12,12">
                <TextBlock x:Name="AsciiArtDisplay"
                           Foreground="#00FFFF"
                           FontSize="7"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"
                           TextWrapping="NoWrap"/>
            </ScrollViewer>

            <Rectangle Height="1" Fill="#1E3A5F" Margin="12,0,12,0"/>
        </StackPanel>

        <!-- Row 1: Chat history -->
        <RichTextBox x:Name="ChatDisplay"
             Grid.Row="1"
             Margin="12,8,12,8"
             IsReadOnly="True"
             Background="#0A0E1A"
             Foreground="White"
             BorderThickness="0"
             VerticalScrollBarVisibility="Auto"/>

        <!-- Row 2: Input row -->
        <Grid Grid.Row="2" Margin="12,4,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInput"
                     Grid.Column="0"
                     Background="#0D1B2A"
                     Foreground="#00FFFF"
                     CaretBrush="#00FFFF"
                     BorderBrush="#1E3A5F"
                     BorderThickness="1"
                     FontSize="13"
                     FontFamily="Consolas"
                     Padding="8,6"
                     VerticalContentAlignment="Center"
                     KeyDown="UserInput_KeyDown"/>

            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="Send"
                    Width="80"
                    Margin="8,0,0,0"
                    Background="#00FFFF"
                    Foreground="#0A0E1A"
                    FontWeight="Bold"
                    FontSize="13"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SendButton_Click"/>
        </Grid>
    </Grid>
</Window>

