<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Bot"
        Height="700" Width="1050"
        Background="#0A0E1A"
        FontFamily="Consolas">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <Grid.ColumnDefinition Width="2*"/>
            <Grid.ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: Header (Spans across both columns) -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Background="#0D1B2A" Margin="0,0,0,4">
            <TextBlock Text="⚡ CyberSecurity Bot"
                       Foreground="#00FFFF"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,8"/>

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="12,0,12,12">
                <TextBlock x:Name="AsciiArtDisplay"
                           Foreground="#00FFFF"
                           FontSize="7"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"
                           TextWrapping="NoWrap"/>
            </ScrollViewer>

            <Rectangle Height="1" Fill="#1E3A5F" Margin="12,0,12,0"/>
        </StackPanel>

        <!-- Row 1, Column 0: Chat history -->
        <RichTextBox x:Name="ChatDisplay"
                     Grid.Row="1" Grid.Column="0"
                     Margin="12,8,6,8"
                     IsReadOnly="True"
                     Background="#0D1B2A"
                     Foreground="White"
                     BorderBrush="#1E3A5F"
                     BorderThickness="1"
                     VerticalScrollBarVisibility="Auto"/>

        <!-- Row 1, Column 1: Task Assistant Panel -->
        <Border Grid.Row="1" Grid.Column="1" 
                Background="#0D1B2A" 
                BorderBrush="#1E3A5F" 
                BorderThickness="1" 
                Margin="6,8,12,8" 
                CornerRadius="4">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Task Title Input -->
                <StackPanel Grid.Row="0" Margin="0,4">
                    <Label Content="Task Title:" Foreground="#00FFFF" Padding="0,2"/>
                    <TextBox x:Name="TxtTaskTitle" Background="#0A0E1A" Foreground="White" BorderBrush="#1E3A5F" Height="25"/>
                </StackPanel>

                <!-- Task Description Input -->
                <StackPanel Grid.Row="1" Margin="0,4">
                    <Label Content="Description:" Foreground="#00FFFF" Padding="0,2"/>
                    <TextBox x:Name="TxtTaskDescription" Background="#0A0E1A" Foreground="White" BorderBrush="#1E3A5F" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                </StackPanel>

                <!-- Task Reminder Input -->
                <StackPanel Grid.Row="2" Margin="0,4">
                    <Label Content="Reminder (e.g. 'In 7 days'):" Foreground="#00FFFF" Padding="0,2"/>
                    <TextBox x:Name="TxtTaskReminder" Background="#0A0E1A" Foreground="White" BorderBrush="#1E3A5F" Height="25"/>
                </StackPanel>

                <!-- Action Button: Add Task -->
                <Button x:Name="BtnAddTask" Grid.Row="3" Content="Add Task" Height="28" Margin="0,8,0,8" 
                        Background="#00FFFF" Foreground="#0A0E1A" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAddTask_Click"/>

                <!-- Display Control: DataGrid -->
                <DataGrid x:Name="DgTasks" Grid.Row="4" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                          Background="#0A0E1A" BorderBrush="#1E3A5F" Foreground="White" RowBackground="#0D1B2A" AlternativeRowBackground="#0A0E1A" HeadersVisibility="Column">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1E3A5F"/>
                            <Setter Property="Foreground" Value="#00FFFF"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="4"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="30"/>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="90"/>
                        <DataGridTextColumn Header="Reminder" Binding="{Binding Reminder}" Width="90"/>
                        <DataGridTextColumn Header="Done" Binding="{Binding IsComplete}" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Management Actions -->
                <Grid Grid.Row="5" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnMarkComplete" Grid.Column="0" Content="Complete" Height="28" Margin="0,0,4,0" 
                            Background="#1E3A5F" Foreground="#00FFFF" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnMarkComplete_Click"/>
                    <Button x:Name="BtnDeleteTask" Grid.Column="1" Content="Delete" Height="28" Margin="4,0,0,0" 
                            Background="#FFD32F2F" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnDeleteTask_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Row 2: Input row (Spans across the chat area) -->
        <Grid Grid.Row="2" Grid.Column="0" Margin="12,4,6,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInput"
                     Grid.Column="0"
                     Background="#0D1B2A"
                     Foreground="#00FFFF"
                     CaretBrush="#00FFFF"
                     BorderBrush="#1E3A5F"
                     BorderThickness="1"
                     FontSize="13"
                     FontFamily="Consolas"
                     Padding="8,6"
                     VerticalContentAlignment="Center"
                     KeyDown="UserInput_KeyDown"/>

            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="Send"
                    Width="80"
                    Margin="8,0,0,0"
                    Background="#00FFFF"
                    Foreground="#0A0E1A"
                    FontWeight="Bold"
                    FontSize="13"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SendButton_Click"/>
            <!-- Cybersecurity Quiz Panel -->
            <Border Background="#1E1E2E" BorderBrush="#00FFFF" BorderThickness="1" CornerRadius="5" Padding="15" Margin="10" HorizontalAlignment="Right" Width="320">
                <Grid>
                    <!-- MASTER QUIZ INTERFACE VIEW -->
                    <Grid Name="pnlQuizActive" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Score Header -->
                            <RowDefinition Height="*"/>
                            <!-- Question & Options -->
                            <RowDefinition Height="Auto"/>
                            <!-- Feedback Area -->
                            <RowDefinition Height="Auto"/>
                            <!-- Navigation Buttons -->
                        </Grid.RowDefinitions>

                        <!-- Score Tracker Header (Visible Throughout) -->
                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="CYBER SECURITY QUIZ" Foreground="#00FFFF" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Name="txtQuizScore" Text="Score: 0 / 16" Foreground="White" HorizontalAlignment="Right" FontWeight="Bold"/>
                        </DockPanel>

                        <!-- Question and Interactive Options Container -->
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <!-- Current Question Text -->
                            <TextBlock Name="txtQuizQuestion" Text="Question text will load here..." Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,15" Height="60"/>

                            <!-- Answer Choice RadioButtons -->
                            <RadioButton Name="rbOptionA" Content="Option A" Foreground="White" Margin="0,4" GroupName="CyberQuiz"/>
                            <RadioButton Name="rbOptionB" Content="Option B" Foreground="White" Margin="0,4" GroupName="CyberQuiz"/>
                            <RadioButton Name="rbOptionC" Content="Option C" Foreground="White" Margin="0,4" GroupName="CyberQuiz"/>
                            <RadioButton Name="rbOptionD" Content="Option D" Foreground="White" Margin="0,4" GroupName="CyberQuiz"/>
                        </StackPanel>

                        <!-- Feedback Area (Shows outcome and explanation after submit) -->
                        <TextBlock Grid.Row="2" Name="txtQuizFeedback" Text="" Foreground="#FFED4A" TextWrapping="Wrap" Margin="0,10" Height="50" HorizontalAlignment="Center" TextAlignment="Center"/>

                        <!-- Execution Trigger Action Buttons -->
                        <Grid Grid.Row="3" Margin="0,5,0,0">
                            <Button Name="btnSubmitAnswer" Content="Submit Answer" Background="#00FFFF" Foreground="Black" FontWeight="Bold" Padding="6" Click="btnSubmitAnswer_Click" Visibility="Visible"/>
                            <Button Name="btnNextQuestion" Content="Next Question ➔" Background="#28C76F" Foreground="White" FontWeight="Bold" Padding="6" Click="btnNextQuestion_Click" Visibility="Collapsed"/>
                        </Grid>
                    </Grid>

                    <!-- FINAL RESULTS SUMMARY SCREEN -->
                    <StackPanel Name="pnlQuizResults" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Quiz Completed!" Foreground="#00FFFF" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Name="txtFinalScore" Text="Your Score: 0/16" Foreground="White" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Name="txtFinalMessage" Text="Feedback message goes here..." Foreground="White" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                        <Button Name="btnResetQuiz" Content="Restart Quiz" Background="#00FFFF" Foreground="Black" Padding="8,5" Click="btnResetQuiz_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

























        </Grid>
    </Grid>
</Window>





